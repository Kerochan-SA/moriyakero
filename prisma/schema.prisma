generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model BandMember {
  user_id    String   @id @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz(6)

  @@map("band_members")
}

model LiveSetlistEntry {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  performance_date DateTime @db.Date
  live_name        String
  copy_from        String?
  video_url        String?
  members          Json     @default(dbgenerated("'{}'::jsonb")) @db.JsonB
  songs            String[] @default([])
  my_parts         String[] @default([])
  note             String?
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  updated_at       DateTime @default(now()) @db.Timestamptz(6)
  created_by       String?  @db.Uuid

  @@index([performance_date, live_name], map: "live_setlist_entries_date_live_idx")
  @@map("live_setlist_entries")
}
